@page
@model SharedCents.Pages.Expenses.IndexModel

@{
    ViewData["Title"] = "Expenses";
}

<!-- Page Title -->
<h1 class="mb-3">Expenses</h1>

<!-- Search Form -->
<form method="get" class="mb-3">
    <div class="row">
        <div class="col-md-4">
            <input type="text"
                   name="SearchString"
                   value="@Model.SearchString"
                   class="form-control"
                   placeholder="Search expenses or categories..." />
        </div>

        <div class="col-md-2">
            <button type="submit" class="btn btn-primary">
                Search
            </button>
        </div>
    </div>
</form>

<!-- Create New Expense Button -->
<p>
    <a asp-page="Create" class="btn btn-success">
        Create New Expense
    </a>
</p>

<!-- Expense Table -->
<table class="table table-striped table-hover shadow-sm">
    <thead class="table-light">
        <tr>

            <!-- Sort by Expense Name -->
            <th>
                <a asp-page="./Index"
                   asp-route-sortOrder="@(Model.CurrentSort == "name_desc" ? "" : "name_desc")">
                    Expense Name
                </a>
            </th>

            <th>
                <a asp-page="./Index"
                    asp-route-sortOrder="@(Model.CurrentSort == "category" ? "category_desc" : "category")">
                    Category
                </a>
            </th>

            <!-- Sort by Amount -->
            <th>
                <a asp-page="./Index"
                   asp-route-sortOrder="@(Model.CurrentSort == "amount" ? "amount_desc" : "amount")">
                    Amount
                </a>
            </th>

            <th>
                Due Date
            </th>

            <th>
                Paid
            </th>

            <th>
                Shared
            </th>

            <th>
                Partner
            </th>

            <th></th>
        </tr>
    </thead>

    <tbody>
@foreach (var item in Model.Expense)
{
        <tr>
            <td>
                @item.ExpenseName
            </td>

            <td>
                @item.Category
            </td>

            <td>
                $@item.Amount
            </td>

            <td>
                @item.DueDate.ToShortDateString()
            </td>

            <td>
                @item.IsPaid
            </td>

            <td>
                @item.IsShared
            </td>

            <td>
                @item.Partner.Email
            </td>

            <td>
                <a asp-page="./Edit" asp-route-id="@item.ExpenseId">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.ExpenseId">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.ExpenseId">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>

<!-- Pagination Buttons -->
<div class="mt-3">

    @if (Model.CurrentPage > 1)
    {
        <a asp-page="./Index"
           asp-route-pageNumber="@(Model.CurrentPage - 1)"
           asp-route-searchString="@Model.SearchString"
           asp-route-sortOrder="@Model.CurrentSort"
           class="btn btn-outline-primary">
            Previous
        </a>
    }

    <span class="mx-2">
        Page @Model.CurrentPage of @Model.TotalPages
    </span>

    @if (Model.CurrentPage < Model.TotalPages)
    {
        <a asp-page="./Index"
           asp-route-pageNumber="@(Model.CurrentPage + 1)"
           asp-route-searchString="@Model.SearchString"
           asp-route-sortOrder="@Model.CurrentSort"
           class="btn btn-outline-primary">
            Next
        </a>
    }

</div>